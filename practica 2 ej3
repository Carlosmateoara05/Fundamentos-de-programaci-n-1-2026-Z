#include <stdio.h>

int main() {
    float parcial1, parcial2, examen_final, proyecto, nota_final;

    
    printf("Ingrese la nota del primer parcial (0 a 25 puntos): ");
    scanf("%f", &parcial1);
    
    printf("Ingrese la nota del segundo parcial (0 a 25 puntos): ");
    scanf("%f", &parcial2);
    
    printf("Ingrese la nota del examen final (0 a 30 puntos): ");
    scanf("%f", &examen_final);
    
    printf("Ingrese la nota del proyecto integrador (0 a 20 puntos): ");
    scanf("%f", &proyecto);

    
    nota_final = parcial1 + parcial2 + examen_final + proyecto;

    
    printf("\n--- Resultados ---\n");
    printf("Nota Final: %.2f / 100.00\n", nota_final);

    if (nota_final >= 51) {
        printf("Estado: APROBÓ\n");
    } else {
        printf("Estado: REPROBÓ\n");
    }

    return 0;
}
